    "js-yaml": "4.x",
    "ffi-napi": "4.x",
    "pidusage": "3.x",
    "react": "18.x",
    "react-dom": "18.x",
    "react-router-dom": "6.x",
    "recharts": "2.x",
    "serve-handler": "6.x",
    "systeminformation": "5.x",
    "tailwindcss": "3.x",
    "zustand": "4.x"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "4.x",
    "concurrently": "8.x",
    "electron-builder": "24.x",
