  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build:react": "vite build --outDir dist-react",
    "build": "npm run build:react && electron-builder"
  },
  "dependencies": {
